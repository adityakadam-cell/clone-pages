# Copy to .env and fill in. Never commit the real .env.
SECRET_KEY=change-me-to-a-long-random-string
MAX_UPLOAD_FILES=10
MAX_UPLOAD_MB=15

# Google API key with the Sheets API enabled — required to read Doc-cell
# hyperlinks from a Google Sheet (Google's CSV export drops them).
# Create at https://console.cloud.google.com/apis/credentials and enable
# "Google Sheets API". The sheet AND the linked Google Docs must be shared
# as "Anyone with the link can view".
GOOGLE_API_KEY=your-google-api-key-here

# Service account for reading Google Docs (the Docs API rejects API keys).
# Either a path to the JSON key file, or the raw JSON string.
# Local dev: easiest is a path, e.g. ./service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
